# claw-code local model runner example.
# Copy to local/env.local and change only the values you need.

# Supported profiles:
# - gemma-4-e4b
# - gemma-4-e2b
# - qwen-coder-7b
# - qwen-coder-3b
# - qwen-coder-1.5b
LOCAL_MODEL_PROFILE=qwen-coder-7b

# Supported backends:
# - ollama
# - llamacpp
# - vllm
# - lmstudio
# - openai-compatible
LOCAL_BACKEND=ollama

# Optional override. Leave empty to use the backend default.
# Ollama:    http://127.0.0.1:11434/v1
# llama.cpp: http://127.0.0.1:8080/v1
# vLLM:      http://127.0.0.1:8000/v1
# LM Studio: http://127.0.0.1:1234/v1
LOCAL_OPENAI_BASE_URL=

# Optional override for the model name sent to the backend.
# Use this when your Ollama tag, llama.cpp --alias, or LM Studio model id differs
# from the profile default.
LOCAL_MODEL_ID=

# Local servers often ignore the key but OpenAI-compatible clients still expect one.
LOCAL_API_KEY=local-dev-token

# claw-code options.
LOCAL_CLAW_BIN=rust/target/debug/claw
LOCAL_CLAW_PERMISSION_MODE=workspace-write
